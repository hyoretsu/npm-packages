{
	"name": "project",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "",
		"dev": "",
		"format": "bun format:biome . & bun format:eslint .",
		"format:biome": "biome check --diagnostic-level=error --write --unsafe",
		"format:eslint": "eslint --quiet --fix",
		"generate": "(prisma generate && npm run format:biome ./src/infra/sql/kysely/types.ts) || true",
		"migrate": "prisma migrate dev --create-only && bun run generate",
		"migrate:dev": "prisma migrate dev && bun run generate",
		"migrate:deploy": "prisma migrate deploy",
		"postinstall": "bun run generate",
		"prepare": "bun ./prepare.ts || true",
		"test": "bun test",
		"start": "",
		"start:debug": "",
		"start:prod": ""
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@hyoretsu/configs": "^1.2.13",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0",
		"committier": "^0.2.3",
		"eslint": "^10.0.3",
		"eslint-config-biome": "^2.1.3",
		"lint-staged": "^16.4.0",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	}
}
