{
	"name": "@hyoretsu/providers",
	"description": "A collection of useful providers for Node.js",
	"version": "2.1.0",
	"keywords": [
		"backend",
		"nodejs",
		"providers",
		"utils"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./cache": {
			"import": {
				"types": "./dist/CacheProvider/index.d.ts",
				"default": "./dist/CacheProvider/index.js"
			},
			"require": {
				"types": "./dist/CacheProvider/index.d.cts",
				"default": "./dist/CacheProvider/index.cjs"
			}
		},
		"./hash": {
			"import": {
				"types": "./dist/HashProvider/index.d.ts",
				"default": "./dist/HashProvider/index.js"
			},
			"require": {
				"types": "./dist/HashProvider/index.d.cts",
				"default": "./dist/HashProvider/index.cjs"
			}
		},
		"./jwt": {
			"import": {
				"types": "./dist/JwtProvider/index.d.ts",
				"default": "./dist/JwtProvider/index.js"
			},
			"require": {
				"types": "./dist/JwtProvider/index.d.cts",
				"default": "./dist/JwtProvider/index.cjs"
			}
		},
		"./mail": {
			"import": {
				"types": "./dist/MailProvider/index.d.ts",
				"default": "./dist/MailProvider/index.js"
			},
			"require": {
				"types": "./dist/MailProvider/index.d.cts",
				"default": "./dist/MailProvider/index.cjs"
			}
		},
		"./messaging": {
			"import": {
				"types": "./dist/MessagingProvider/index.d.ts",
				"default": "./dist/MessagingProvider/index.js"
			},
			"require": {
				"types": "./dist/MessagingProvider/index.d.cts",
				"default": "./dist/MessagingProvider/index.cjs"
			}
		},
		"./logging": {
			"import": {
				"types": "./dist/LoggingProvider/index.d.ts",
				"default": "./dist/LoggingProvider/index.js"
			},
			"require": {
				"types": "./dist/LoggingProvider/index.d.cts",
				"default": "./dist/LoggingProvider/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"homepage": "https://github.com/hyoretsu/npm-packages/tree/main/packages/providers",
	"bugs": {
		"url": "https://github.com/hyoretsu/npm-packages/issues",
		"email": "hyoretsu@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hyoretsu/npm-packages.git"
	},
	"license": "MIT",
	"author": {
		"name": "Aran Leite",
		"email": "hyoretsu@gmail.com",
		"url": "https://www.linkedin.com/in/aranleite"
	},
	"scripts": {
		"build": "tsup && tsc --emitDeclarationOnly",
		"prepublishOnly": "bun run build",
		"check-types": "tsc --noEmit",
		"publish": "npm publish --provenance --access public"
	},
	"dependencies": {
		"iso8601-duration": "^2.1.2"
	},
	"devDependencies": {
