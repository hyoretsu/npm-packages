{
	"name": "npm-packages",
	"private": true,
	"scripts": {
		"format": "bun --parallel 'bun format:biome .' 'bun format:eslint .'",
		"format:biome": "biome check --diagnostic-level=error --write --unsafe",
		"format:eslint": "eslint --quiet --fix",
		"prepare": "bun run ./prepare.ts || true"
	},
	"dependencies": {
		"npm": "^11.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@hyoretsu/configs": "^1.2.17",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"committier": "^0.2.3",
		"eslint": "^10.1.0",
		"eslint-config-biome": "^2.1.3",
		"lint-staged": "^16.4.0",
		"tsup": "^8.5.1",
		"typescript-eslint": "^8.57.2"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@swc/core",
		"bcrypt",
		"esbuild",
		"protobufjs"
	]
}
